generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  password_hash String
  role          String         @default("recruit") // "recruit" | "admin"
  created_at    DateTime       @default(now())
  TaskStatus    TaskStatus[]
  notifications Notification[]
  doubtsAuthored Doubt[]       @relation("DoubtAuthor")
  doubtsAbout   Doubt[]        @relation("DoubtRecruit")
}

model AllowlistEntry {
  id         String   @id @default(uuid())
  email      String   @unique
  added_by   String   // Admin user id
  created_at DateTime @default(now())
}

model Task {
  id          String       @id @default(uuid())
  number      Int
  title       String
  description String
  resources   String?      // comma-separated or newline-separated resource URLs or title|url
  order       Int
  TaskStatus  TaskStatus[]
  doubts      Doubt[]
}

model TaskStatus {
  id              String   @id @default(uuid())
  user_id         String
  task_id         String
  status          String   @default("not_started") // "not_started" | "in_progress" | "stuck" | "finished" | "skipped"
  submission_link String?
  submission_note String?
  verdict         String   @default("pending") // "pending" | "approved" | "needs_revision"
  admin_comment   String?
  updated_at      DateTime @updatedAt

  user User @relation(fields: [user_id], references: [id])
  task Task @relation(fields: [task_id], references: [id])

  @@unique([user_id, task_id])
}

model Doubt {
  id           String   @id @default(uuid())
  task_id      String
  recruit_id   String   // The recruit this discussion belongs to
  author_id    String   // The sender of the message
  author_email String
  content      String
  created_at   DateTime @default(now())

  task    Task @relation(fields: [task_id], references: [id], onDelete: Cascade)
  recruit User @relation("DoubtRecruit", fields: [recruit_id], references: [id], onDelete: Cascade)
  author  User @relation("DoubtAuthor", fields: [author_id], references: [id], onDelete: Cascade)
}

model Notification {
  id         String   @id @default(uuid())
  user_id    String   // Recipient user
  title      String
  message    String
  link       String
  is_read    Boolean  @default(false)
  created_at DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
}


